<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>My Game Site</title>

<style>
body {
  margin: 0;
  background: #111;
  font-family: Arial;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

/* BUTTON STYLE */
.game-button {
  padding: 20px 40px;
  font-size: 22px;
  background: #4CAF50;
  color: white;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  transition: 0.2s;
}

.game-button:hover {
  transform: scale(1.1);
  background: #3e8e41;
}
</style>

</head>

<body>

<button class="game-button" onclick="openGame()">
  Play Football Bros
</button>

<script>
function openGame() {
  window.open("https://www.gameflare.com/embed/football-bros/", "_blank");
}
</script>

</body>
</html>
